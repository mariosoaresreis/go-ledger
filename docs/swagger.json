{
    "swagger": "2.0",
    "info": {
        "description": "Write-side of the CQRS ledger: account creation, credits, debits, transfers.",
        "title": "Ledger Command Service API",
        "termsOfService": "http://example.com/terms/",
        "contact": {
            "name": "Ledger Team",
            "email": "ledger@example.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/v1/accounts": {
            "post": {
                "description": "Creates a ledger account for an owner",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "accounts"
                ],
                "summary": "Create a new account",
                "parameters": [
                    {
                        "description": "Create account request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/services.CreateAccountRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.Account"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/accounts/{accountId}/credits": {
            "post": {
                "description": "Adds funds to an account",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "accounts"
                ],
                "summary": "Credit an account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account ID",
                        "name": "accountId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key (UUID)",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Credit request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/services.CreditRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.LedgerEvent"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/accounts/{accountId}/debits": {
            "post": {
                "description": "Withdraws funds from an account",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "accounts"
                ],
                "summary": "Debit an account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account ID",
                        "name": "accountId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Idempotency key (UUID)",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Debit request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/services.DebitRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.LedgerEvent"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/accounts/{accountId}/events": {
            "get": {
                "description": "Returns the full audit trail of events for an account",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "accounts"
                ],
                "summary": "Get raw event log",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account ID",
                        "name": "accountId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.LedgerEvent"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/accounts/{accountId}/status": {
            "patch": {
                "description": "Sets an account to ACTIVE, FROZEN, or CLOSED",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "accounts"
                ],
                "summary": "Change account status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account ID",
                        "name": "accountId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Status change request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/services.ChangeStatusRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.LedgerEvent"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/transfers": {
            "post": {
                "description": "Initiates a choreography saga: debits source, credits target",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "transfers"
                ],
                "summary": "Initiate a transfer",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Idempotency key (UUID)",
                        "name": "Idempotency-Key",
                        "in": "header"
                    },
                    {
                        "description": "Transfer request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/services.TransferRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/domain.LedgerEvent"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "domain.Account": {
            "type": "object",
            "properties": {
                "balance": {
                    "description": "stored as minor units (cents)",
                    "type": "integer"
                },
                "createdAt": {
                    "type": "string"
                },
                "currency": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "ownerID": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/domain.AccountStatus"
                },
                "updatedAt": {
                    "type": "string"
                },
                "version": {
                    "type": "integer"
                }
            }
        },
        "domain.AccountStatus": {
            "type": "string",
            "enum": [
                "ACTIVE",
                "FROZEN",
                "CLOSED"
            ],
            "x-enum-varnames": [
                "StatusActive",
                "StatusFrozen",
                "StatusClosed"
            ]
        },
        "domain.EventType": {
            "type": "string",
            "enum": [
                "ACCOUNT_CREATED",
                "ACCOUNT_CREDITED",
                "ACCOUNT_DEBITED",
                "ACCOUNT_STATUS_CHANGED",
                "TRANSFER_INITIATED",
                "TRANSFER_COMPLETED",
                "TRANSFER_REVERSED"
            ],
            "x-enum-varnames": [
                "EventAccountCreated",
                "EventAccountCredited",
                "EventAccountDebited",
                "EventAccountStatusChanged",
                "EventTransferInitiated",
                "EventTransferCompleted",
                "EventTransferReversed"
            ]
        },
        "domain.LedgerEvent": {
            "type": "object",
            "properties": {
                "aggregateID": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "eventType": {
                    "$ref": "#/definitions/domain.EventType"
                },
                "id": {
                    "type": "string"
                },
                "payload": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "version": {
                    "type": "integer"
                }
            }
        },
        "services.ChangeStatusRequest": {
            "type": "object",
            "required": [
                "status"
            ],
            "properties": {
                "status": {
                    "enum": [
                        "ACTIVE",
                        "FROZEN",
                        "CLOSED"
                    ],
                    "allOf": [
                        {
                            "$ref": "#/definitions/domain.AccountStatus"
                        }
                    ]
                }
            }
        },
        "services.CreateAccountRequest": {
            "type": "object",
            "required": [
                "currency",
                "ownerId"
            ],
            "properties": {
                "currency": {
                    "type": "string"
                },
                "ownerId": {
                    "type": "string"
                }
            }
        },
        "services.CreditRequest": {
            "type": "object",
            "required": [
                "amount",
                "currency",
                "reference"
            ],
            "properties": {
                "amount": {
                    "type": "integer"
                },
                "currency": {
                    "type": "string"
                },
                "reference": {
                    "type": "string"
                }
            }
        },
        "services.DebitRequest": {
            "type": "object",
            "required": [
                "amount",
                "currency",
                "reference"
            ],
            "properties": {
                "amount": {
                    "type": "integer"
                },
                "currency": {
                    "type": "string"
                },
                "reference": {
                    "type": "string"
                }
            }
        },
        "services.TransferRequest": {
            "type": "object",
            "required": [
                "amount",
                "currency",
                "sourceAccountId",
                "targetAccountId"
            ],
            "properties": {
                "amount": {
                    "type": "integer"
                },
                "currency": {
                    "type": "string"
                },
                "sourceAccountId": {
                    "type": "string"
                },
                "targetAccountId": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}